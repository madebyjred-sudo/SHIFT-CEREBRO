# ═══════════════════════════════════════════════════════════════
# Shift Chat — Environment Variables for Hostinger VPS Deploy
# ═══════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   1. Copy to .env.shift-chat on VPS
#   2. Fill in ALL values marked with TODO
#   3. Run: docker compose -f docker-compose.shift-chat.yml --env-file .env.shift-chat up -d
#

# ─── LobeChat Core ─────────────────────────────────────────
LOBE_PORT=3210

# ─── Auth (REQUIRED) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=TODO_GENERATE_WITH_openssl_rand_base64_32

# ─── Database ─────────────────────────────────────────────
LOBE_DB_NAME=shift_chat
POSTGRES_PASSWORD=TODO_set_strong_password
DATABASE_URL=postgresql://postgres:TODO_set_strong_password@postgresql:5432/shift_chat

# ─── S3 / RustFS ──────────────────────────────────────────
RUSTFS_PORT=9000
RUSTFS_ACCESS_KEY=shift_rustfs_access
RUSTFS_SECRET_KEY=TODO_set_strong_secret
S3_ENDPOINT=http://network-service:9000
S3_BUCKET=shift-chat
S3_ACCESS_KEY_ID=shift_rustfs_access
S3_SECRET_ACCESS_KEY=TODO_set_strong_secret
S3_REGION=us-east-1
S3_PUBLIC_DOMAIN=TODO_your_vps_ip_or_domain:9000
S3_ENABLE_PATH_STYLE=1

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ═══════════════════════════════════════════════════════════════
# CEREBRO INTEGRATION (THE IMPORTANT PART)
# ═══════════════════════════════════════════════════════════════

# OpenAI proxy → points to Cerebro's OpenAI-compat adapter on Railway
OPENAI_API_KEY=sk-cerebro-shift-chat-2026
OPENAI_PROXY_URL=https://web-production-143119.up.railway.app/adapter/v1
OPENAI_MODEL_LIST=+cerebro-core

# Enable only OpenAI (our Cerebro adapter) — disable everything else
ENABLED_OPENAI=1
ENABLED_OLLAMA=0
ENABLED_ANTHROPIC=0
ENABLED_GOOGLE=0
ENABLED_AZURE_OPENAI=0
ENABLED_BEDROCK=0
ENABLED_DEEPSEEK=0
ENABLED_GROQ=0
ENABLED_MINIMAX=0
ENABLED_MISTRAL=0
ENABLED_MOONSHOT=0
ENABLED_PERPLEXITY=0
ENABLED_QWEN=0
ENABLED_STEPFUN=0
ENABLED_ZHIPU=0
ENABLED_TOGETHERAI=0
ENABLED_FIREWORKSAI=0
ENABLED_NOVITA=0
ENABLED_BAICHUAN=0
ENABLED_TAICHU=0
ENABLED_AI360=0
ENABLED_SILICONCLOUD=0
ENABLED_UPSTAGE=0
ENABLED_SPARK=0
ENABLED_AI21=0
ENABLED_HUNYUAN=0
ENABLED_WENXIN=0
ENABLED_ZEROONE=0
ENABLED_SENSENOVA=0
ENABLED_INTERNLM=0
ENABLED_HIGRESS=0
ENABLED_GITEE_AI=0
ENABLED_PPIO=0
ENABLED_XAI=0
ENABLED_INFINI=0
ENABLED_OPENROUTER=0
ENABLED_GITHUB=0
ENABLED_HUGGINGFACE=0
ENABLED_VOLCENGINE=0
ENABLED_CLOUDFLARE=0
ENABLED_SAMBANOVA=0
ENABLED_JINA=0
ENABLED_SEARCH1API=0

# Agent market → Cerebro's 15 agents
AGENTS_INDEX_URL=https://web-production-143119.up.railway.app/market

# Default agent config
DEFAULT_AGENT_CONFIG=model=cerebro-core

# ─── Fonts (Shift branding) ──────────────────────────────
NEXT_PUBLIC_CUSTOM_FONT_URL=https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&family=Fira+Sans:wght@400;500;600;700&display=swap
NEXT_PUBLIC_CUSTOM_FONT_FAMILY=Fira Sans

# ═══════════════════════════════════════════════════════════════
# TODO FOR JRED — Fill these before deploying
# ═══════════════════════════════════════════════════════════════
#
# 1. AUTH_SECRET — generate: openssl rand -base64 32
# 2. POSTGRES_PASSWORD — pick something strong, update DATABASE_URL too
# 3. RUSTFS_SECRET_KEY + S3_SECRET_ACCESS_KEY — same value, pick strong
# 4. S3_PUBLIC_DOMAIN — your VPS IP or domain, e.g. vps123.hostinger.com:9000
# 5. (Optional) SMTP for email auth:
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=465
#    SMTP_USER=your@email.com
#    SMTP_PASS=app_password
#    SMTP_FROM=noreply@shift.lat
# 6. (Optional) ALLOWED_ORIGINS on Railway Cerebro — add VPS domain
# 7. (Optional) NEXT_PUBLIC_BASE_PATH if behind reverse proxy
#
# Once filled: docker compose -f docker-compose.shift-chat.yml --env-file .env.shift-chat up -d
# Access at: http://YOUR_VPS_IP:3210
