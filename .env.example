# ==========================================
# Shift Cerebro - Environment Variables
# Para Railway: Configura estas variables en el dashboard
# ==========================================

# OpenRouter API Configuration (REQUIRED)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MySQL Database Configuration (REQUIRED para El Peaje)
MYSQL_HOST=your-mysql-host
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-mysql-database
MYSQL_PORT=3306

# CORS Configuration (REQUIRED)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://your-frontend-domain.com

# ==========================================
# NOTAS DE DEPLOYMENT EN RAILWAY
# ==========================================
# 1. Ve a tu proyecto en Railway dashboard
# 2. Selecciona el servicio "shift-cerebro"
# 3. Ve a la pestaña "Variables"
# 4. Agrega cada variable con su valor correspondiente
# 5. Para MySQL en Railway: Usa el plugin MySQL que ofrece Railway
#    y las variables se configuran automáticamente
#
# MODELOS SOPORTADOS:
# - Claude Opus 4.6 (recomendado para debate)
# - Claude Sonnet 4.6
# - Gemini 3.1 Pro
# - Gemini 3.1 Flash Lite
# - DeepSeek V3.2
# - Moonshot Kimi K2.5
#
# STREAMING: El debate ahora usa NDJSON streaming para evitar timeouts
